{
  "$schema": "https://raw.githubusercontent.com/google-gemini/gemini-cli/main/schemas/settings.schema.json",
  "general": {
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d"
    },
    "vimMode": true
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "folderTrust": {
      "enabled": true
    },
    "environmentVariableRedaction": {
      "enabled": true
    }
  },
  "privacy": {
    "usageStatisticsEnabled": false
  },
  "context": {
    "fileFiltering": {
      "respectGitIgnore": true,
      "respectGeminiIgnore": true
    }
  },
  "tools": {
    "useRipgrep": true,
    "shell": {
      "backgroundCompletionBehavior": "inject"
    }
  },
  "model": {
    "name": "gemini-3.1-pro-preview",
    "compressionThreshold": 0.7
  },
  "ui": {
    "inlineThinkingMode": "full",
    "showHomeDirectoryWarning": true,
    "loadingPhrases": "off",
    "showStatusInTitle": true,
    "useAlternateBuffer": true,
    "footer": {
      "showLabels": true,
      "items": [
        "session-id",
        "model-name",
        "context-used",
        "token-count",
        "memory-usage",
        "quota",
        "workspace",
        "git-branch",
        "code-changes",
        "sandbox",
        "auth"
      ]
    }
  },
  "experimental": {
    "worktrees": true,
    "modelSteering": true
  },
  "hooksConfig": {
    "enabled": true,
    "notifications": true
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/rh1/.gemini/hooks/secret-scan.py",
            "name": "secret-scan"
          }
        ]
      },
      {
        "matcher": "read_file",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/rh1/.gemini/hooks/sensitive-read.py",
            "name": "sensitive-read"
          }
        ]
      }
    ]
  }
}