[core]
	editor = nvim
	commentChar = >
	quotepath = false
	pager = delta
	excludesfile = /Users/rh1/.gitignore_global

[user]
	name = gakkyTaihasoeru
	email = gakky.taihasoeru@gmail.com
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIPEdA62Ic8Ss32IkYxOCLM0bpJ5CxzFXNKn1zOSQ3MgO

[commit]
	gpgsign = true
	verbose = true

[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

[init]
	defaultBranch = main

[merge]
	ff = false
	conflictStyle = zdiff3

[pull]
	ff = only
	rebase = false

[push]
	default = current
	autoSetupRemote = true
	followTags = true

[rebase]
	autoStash = true
	autoSquash = true
	updateRefs = true

[fetch]
	prune = true
	pruneTags = true
	fsckObjects = true

[transfer]
	fsckObjects = true

[receive]
	fsckObjects = true

[branch]
	sort = -committerdate

[rerere]
	enabled = true
	autoUpdate = true

[diff]
	algorithm = histogram
	colorMoved = default
	colorMovedWS = allow-indentation-change

[delta]
	navigate = true
	dark = true
	side-by-side = true
	line-numbers = true
	syntax-theme = Catppuccin Mocha

[tag]
	sort = version:refname

[interactive]
	diffFilter = delta --color-only

[column]
	ui = auto

[help]
	autocorrect = prompt

[ghq]
	root = /Users/rh1/work/ghq
