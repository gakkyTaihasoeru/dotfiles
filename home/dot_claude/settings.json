{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "env": {
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git grep:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)",
      "Bash(git tag:*)",
      "Bash(git remote:*)",
      "Bash(git config --get:*)",
      "Bash(terraform fmt:*)",
      "Bash(terraform validate:*)",
      "Bash(terraform plan:*)",
      "Bash(terraform show:*)",
      "Bash(terraform providers:*)",
      "Bash(terraform version:*)",
      "Bash(terraform workspace show:*)",
      "Bash(terraform init -backend=false:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl top:*)",
      "Bash(kubectl explain:*)",
      "Bash(kubectl api-resources:*)",
      "Bash(kubectl api-versions:*)",
      "Bash(kubectl version:*)",
      "Bash(kubectl config current-context:*)",
      "Bash(kubectl config get-contexts:*)",
      "Bash(kubectl config view:*)",
      "Bash(helm list:*)",
      "Bash(helm status:*)",
      "Bash(helm get:*)",
      "Bash(helm history:*)",
      "Bash(helm show:*)",
      "Bash(helm version:*)",
      "Bash(helm template:*)",
      "Bash(docker ps:*)",
      "Bash(docker images:*)",
      "Bash(docker inspect:*)",
      "Bash(docker logs:*)",
      "Bash(docker version:*)",
      "Bash(docker info:*)",
      "Bash(aws sts get-caller-identity:*)",
      "Bash(aws s3 ls:*)",
      "Bash(aws ec2 describe-:*)",
      "Bash(aws logs describe-:*)",
      "Bash(aws logs tail:*)",
      "Bash(aws logs filter-log-events:*)",
      "Bash(aws cloudwatch describe-:*)",
      "Bash(aws cloudwatch get-metric-:*)",
      "Bash(aws iam list-:*)",
      "Bash(aws iam get-:*)",
      "Bash(gcloud auth list:*)",
      "Bash(gcloud config list:*)",
      "Bash(gcloud projects list:*)",
      "Bash(gcloud compute instances list:*)",
      "Bash(gcloud compute instances describe:*)",
      "Bash(gcloud logging read:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(dig:*)",
      "Bash(nslookup:*)",
      "Bash(host:*)",
      "Bash(ping -c:*)",
      "Bash(traceroute:*)",
      "Bash(curl -I:*)",
      "Bash(curl -sS:*)",
      "Bash(curl -fsSL:*)",
      "Bash(ss:*)",
      "Bash(netstat:*)",
      "Bash(ps:*)",
      "Bash(top -b:*)",
      "Bash(df:*)",
      "Bash(du:*)",
      "Bash(free:*)",
      "Bash(uname:*)",
      "Bash(uptime:*)",
      "Bash(whoami:*)",
      "Bash(date:*)",
      "Bash(pwd:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(awk:*)",
      "Bash(sed -n:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(env:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Edit(./docs/**)",
      "Edit(./runbooks/**)",
      "Edit(./terraform/**/*.tf)",
      "Edit(./terraform/**/*.tfvars.example)",
      "Edit(./helm/**/*.yaml)",
      "Edit(./helm/**/*.yml)",
      "Edit(./k8s/**/*.yaml)",
      "Edit(./kubernetes/**/*.yaml)",
      "Edit(./manifests/**/*.yaml)",
      "Edit(./.github/workflows/**)",
      "Edit(./scripts/**/*.sh)",
      "Edit(./scripts/**/*.py)",
      "Edit(./monitoring/**/*.yaml)",
      "Edit(./dashboards/**)",
      "Edit(./alerts/**)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(mkfs.:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(halt:*)",
      "Bash(poweroff:*)",
      "Bash(chmod -R 777 /:*)",
      "Bash(chown -R root /:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard origin/main:*)",
      "Bash(git reset --hard origin/master:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git filter-branch:*)",
      "Bash(terraform destroy:*)",
      "Bash(terraform force-unlock:*)",
      "Bash(terraform state rm:*)",
      "Bash(terraform state mv:*)",
      "Bash(terraform state push:*)",
      "Bash(terraform workspace delete:*)",
      "Bash(kubectl delete ns:*)",
      "Bash(kubectl delete namespace:*)",
      "Bash(kubectl drain:*)",
      "Bash(kubectl taint:*)",
      "Bash(helm uninstall:*)",
      "Bash(docker system prune:*)",
      "Bash(docker volume prune:*)",
      "Bash(docker network prune:*)"
    ],
    "ask": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git revert:*)",
      "Bash(git stash:*)",
      "Bash(kubectl apply:*)",
      "Bash(kubectl delete:*)",
      "Bash(kubectl patch:*)",
      "Bash(kubectl edit:*)",
      "Bash(kubectl scale:*)",
      "Bash(kubectl rollout:*)",
      "Bash(kubectl cordon:*)",
      "Bash(kubectl uncordon:*)",
      "Bash(kubectl label:*)",
      "Bash(kubectl annotate:*)",
      "Bash(kubectl port-forward:*)",
      "Bash(kubectl exec:*)",
      "Bash(kubectl cp:*)",
      "Bash(helm upgrade:*)",
      "Bash(helm rollback:*)",
      "Bash(helm install:*)",
      "Bash(terraform apply:*)",
      "Bash(terraform init:*)",
      "Bash(docker build:*)",
      "Bash(docker run:*)",
      "Bash(docker exec:*)",
      "Bash(docker stop:*)",
      "Bash(aws s3 cp:*)",
      "Bash(aws s3 sync:*)",
      "Bash(aws s3 rm:*)",
      "Bash(curl -X POST:*)",
      "Bash(curl -X PUT:*)",
      "Bash(curl -X DELETE:*)",
      "Bash(curl -X PATCH:*)"
    ]
  },
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/rh1/.claude/hooks/secret-scan.py"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/rh1/.claude/hooks/sensitive-read.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/rh1/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": true
  }
}
